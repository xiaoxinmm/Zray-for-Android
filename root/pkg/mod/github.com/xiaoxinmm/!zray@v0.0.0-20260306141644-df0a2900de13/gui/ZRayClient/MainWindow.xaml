<wpfui:FluentWindow x:Class="ZRayClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ZRay" Height="580" Width="420"
        Icon="Assets/icon.png"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <wpfui:TitleBar Grid.Row="0" Title="ZRay" ShowMaximize="False"/>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,0">
            <StackPanel Margin="0,8,0,20">

                <!-- Status Card -->
                <wpfui:Card Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="#888"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusText" Text="未连接" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock x:Name="LatencyText" Text="- ms" FontSize="12" Foreground="#888"/>
                        </StackPanel>
                        <wpfui:Button x:Name="BtnConnect" Grid.Column="2"
                                      Content="连 接" Appearance="Primary"
                                      Click="OnToggleConnect" Width="80" Height="36"/>
                    </Grid>
                </wpfui:Card>

                <!-- Speed Stats -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <wpfui:Card Grid.Column="0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="↑ 上传" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="UpSpeed" Text="0 B/s" FontSize="18" FontWeight="Bold"
                                       Foreground="#53CF5E" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </wpfui:Card>

                    <wpfui:Card Grid.Column="2">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="↓ 下载" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DownSpeed" Text="0 B/s" FontSize="18" FontWeight="Bold"
                                       Foreground="#00B4D8" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </wpfui:Card>
                </Grid>

                <!-- Connection Stats -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <wpfui:Card Grid.Column="0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="活跃" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="ConnCount" Text="0" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </wpfui:Card>

                    <wpfui:Card Grid.Column="2">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="直连" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DirectCount" Text="0" FontSize="16" FontWeight="Bold"
                                       Foreground="#53CF5E" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </wpfui:Card>

                    <wpfui:Card Grid.Column="4">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="代理" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="ProxyCount" Text="0" FontSize="16" FontWeight="Bold"
                                       Foreground="#E94560" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </wpfui:Card>
                </Grid>

                <!-- Server Config -->
                <TextBlock Text="服务器配置" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <wpfui:Card Margin="0,0,0,12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="服务器地址" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                        <wpfui:TextBox x:Name="TxtServer" PlaceholderText="例: 1.2.3.4" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="用户密钥" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                                <wpfui:TextBox x:Name="TxtHash" PlaceholderText="user_hash"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="端口" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                                <wpfui:TextBox x:Name="TxtPort" PlaceholderText="64433"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </wpfui:Card>

                <!-- ZA Link Import -->
                <TextBlock Text="ZA 链接导入" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <wpfui:Card Margin="0,0,0,12" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <wpfui:TextBox x:Name="TxtZALink" PlaceholderText="ZA://..." />
                        <wpfui:Button Grid.Column="2" Content="导入" Appearance="Secondary"
                                      Click="OnImportLink" Height="36"/>
                    </Grid>
                </wpfui:Card>

                <!-- Local Ports -->
                <TextBlock Text="本地端口" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <wpfui:Card Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="智能分流" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                            <wpfui:TextBox x:Name="SmartPortText" PlaceholderText="1080"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="全局代理" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                            <wpfui:TextBox x:Name="GlobalPortText" PlaceholderText="1081"/>
                        </StackPanel>
                    </Grid>
                </wpfui:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</wpfui:FluentWindow>
